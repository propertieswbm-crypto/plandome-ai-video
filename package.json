{
    "name":  "openvideo-studio",
    "version":  "0.1.0",
    "private":  true,
    "engines":  {
                    "node":  "\u003e=22.0.0"
                },
    "scripts":  {
                    "build":  "pnpm --filter @openvideo/web build",
                    "dev":  "pnpm --filter @openvideo/web dev",
                    "lint":  "pnpm -r lint",
